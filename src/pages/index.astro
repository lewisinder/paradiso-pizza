---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FacebookIcon from "@/components/FacebookIcon.astro";
import ReviewCard from "@/components/ReviewCard.astro";
import ScrollFootprints from "@/components/ScrollFootprints.astro";
import cannoliCounter from "@/assets/paradiso-cannoli-counter.jpg";
import napoliTable from "@/assets/paradiso-napoli-table.jpg";
import rooster from "@/assets/paradiso-rooster.jpg";
import storefrontParkRd from "@/assets/paradiso-storefront-park-rd.jpg";
import { addOns, desserts, dips, kidsAddOns, kidsDips, kidsPizzas, pizzas } from "@/data/menu";
import { googleReviews } from "@/data/reviews";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const featured = pizzas.filter(({ name }) =>
  ["Paradiso", "Inferno", "Dante", "Beatrice"].includes(name),
);
const midpoint = Math.ceil(pizzas.length / 2);
const pizzaColumns = [pizzas.slice(0, midpoint), pizzas.slice(midpoint)];
const scrollingReviews = [...googleReviews, ...googleReviews];
const facebook = site.social.find((item) => item.label.toLowerCase() === "facebook") ?? site.social[0];
const aboutPhotos = [
  {
    src: storefrontParkRd,
    alt: "Paradiso Pizza storefront below the Park Road street sign",
    caption: "Park Road, Titirangi",
    modifier: "about-photo-card--storefront",
  },
  {
    src: cannoliCounter,
    alt: "Paradiso team member serving cannoli behind the counter",
    modifier: "about-photo-card--counter",
  },
  {
    src: napoliTable,
    alt: "Napoli table scene with a glass of aperitivo",
    modifier: "about-photo-card--napoli",
  },
];
---

<BaseLayout title={site.name} description={site.description}>
  <ScrollFootprints />

  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero-grid">
      <div>
        <span class="overline">Handmade</span>
        <h1 class="hero-title scrawl" id="hero-title">
          <span>Paradiso</span>
          <span>Pizza</span>
        </h1>
        <p class="lead">
          Pizza, cannoli and tiramisu in Titirangi village. Order online, pick up hot,
          and keep an eye on Facebook for the latest specials.
        </p>
        <div class="hero-actions">
          <a class="btn btn--ghost" href={withBase("#menu")}>View Menu</a>
          <a
            class="btn btn--primary"
            href={withBase(site.orderUrl)}
            target="_blank"
            rel="noopener noreferrer"
          >
            Order Online
          </a>
        </div>
        <div class="footprint-trail footprint-trail--hero" aria-hidden="true">
          <span class="footprint-mark"></span>
          <span class="footprint-mark"></span>
          <span class="footprint-mark"></span>
          <span class="footprint-mark"></span>
        </div>
      </div>

      <figure class="print-frame">
        <Image
          src={rooster}
          alt="Hand-drawn rooster illustration used on the Paradiso Pizza menu"
          widths={[320, 480, 640]}
          sizes="(max-width: 720px) 80vw, 430px"
          loading="eager"
        />
        <figcaption class="print-caption">our mascot</figcaption>
      </figure>
    </div>
  </section>

  <section class="section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-heading">
        <h2 class="scrawl" id="featured-title">Pizza</h2>
        <p class="lead">Our most-loved pies, pulled from the same menu customers order from.</p>
      </div>

      <div class="featured-grid">
        {featured.map((pizza) => (
          <article class="rough-card">
            <h3>{pizza.name}</h3>
            <div class="card-rule" aria-hidden="true"></div>
            <p>{pizza.description}</p>
            <div class="price-row">
              <span class="price">{pizza.price}</span>
            </div>
            {pizza.orderUrl && (
              <a
                class="text-link order-card-link"
                href={pizza.orderUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Order this pizza
              </a>
            )}
          </article>
        ))}
      </div>

      <div class="button-row button-row--center">
        <a class="btn btn--ghost" href={withBase("#menu")}>See full menu</a>
      </div>
    </div>
  </section>

  <section class="section section--surface" id="menu" aria-labelledby="menu-title">
    <div class="container">
      <div class="section-heading section-heading--center">
        <h2 class="scrawl" id="menu-title">The Menu</h2>
        <div class="menu-switch" role="tablist" aria-label="Choose menu">
          <button
            class="menu-switch__button is-active"
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls="main-menu-panel"
            data-menu-target="main"
          >
            Main menu
          </button>
          <button
            class="menu-switch__button menu-switch__button--kids"
            type="button"
            role="tab"
            aria-selected="false"
            aria-controls="kids-menu-panel"
            data-menu-target="kids"
          >
            Kids menu
          </button>
        </div>
      </div>

      <div class="menu-panel is-active" id="main-menu-panel" role="tabpanel" data-menu-panel="main">
        <div class="menu-layout">
          <div>
            <div class="menu-category-title">Pizza</div>
            <dl class="dietary-legend" aria-label="Dietary legend">
              <div>
                <dt>VG</dt>
                <dd>vegetarian</dd>
              </div>
              <div>
                <dt>V</dt>
                <dd>vegan</dd>
              </div>
              <div>
                <dt>GFO</dt>
                <dd>gluten free +$3</dd>
              </div>
            </dl>
            <div class="menu-columns">
              {pizzaColumns.map((column) => (
                <ol class="menu-list">
                  {column.map((pizza) => (
                    <li class="menu-entry">
                      <h3>
                        <span>{pizza.name}</span>
                        {pizza.dietary && (
                          <span class="dietary-mark" aria-label={pizza.dietary === "VG" ? "vegetarian" : "vegan"}>
                            {pizza.dietary}
                          </span>
                        )}
                      </h3>
                      <span class="price">{pizza.price}</span>
                      <p>{pizza.description}</p>
                    </li>
                  ))}
                </ol>
              ))}
            </div>
          </div>

          <aside class="red-board" id="desserts" aria-labelledby="desserts-title">
            <div class="red-board-section">
              <h3 id="desserts-title">Desserts</h3>
              <ol class="menu-list">
                {desserts.map((item) => (
                  <li class="menu-entry">
                    <h3>{item.name}</h3>
                    <span class="price">{item.price}</span>
                    <p>{item.description}</p>
                  </li>
                ))}
              </ol>
            </div>

            <div class="red-board-section">
              <h3>Add-ons</h3>
              <ol class="side-list">
                {addOns.map((item) => (
                  <li>{item.name} {item.price}</li>
                ))}
              </ol>
            </div>

            <div class="red-board-section">
              <h3>Dips <span class="price">$5</span></h3>
              <ol class="side-list">
                {dips.map((item) => (
                  <li>{item.name}</li>
                ))}
              </ol>
            </div>

          <p class="menu-note">
            All pizzas are 12".<br />
            Gluten-free base available +$3.<br />
            Please advise of any allergies.
          </p>
          </aside>
        </div>
      </div>

      <div class="menu-panel" id="kids-menu-panel" role="tabpanel" data-menu-panel="kids" hidden>
        <div class="kids-menu-sheet">
          <div class="kids-menu-sheet__masthead">
            <span>Paradiso</span>
            <strong>Kids menu</strong>
          </div>

          <div class="kids-menu-sheet__grid">
            <ol class="menu-list kids-menu-list">
              {kidsPizzas.map((pizza) => (
                <li class="menu-entry">
                  <h3>{pizza.name}</h3>
                  <span class="price">{pizza.price}</span>
                  <p>{pizza.description}</p>
                </li>
              ))}
            </ol>

            <aside class="red-board kids-red-board" aria-labelledby="kids-extras-title">
              <div class="red-board-section">
                <h3 id="kids-extras-title">Dips <span class="price">$5</span></h3>
                <ol class="side-list">
                  {kidsDips.map((item) => (
                    <li>{item.name}</li>
                  ))}
                </ol>
              </div>

              <div class="red-board-section">
                <h3>Add-ons</h3>
                <ol class="side-list">
                  {kidsAddOns.map((item) => (
                    <li>{item.name} {item.price}</li>
                  ))}
                </ol>
              </div>
            </aside>
          </div>
        </div>
      </div>

      <script>
        const menuSwitchButtons = document.querySelectorAll<HTMLButtonElement>("[data-menu-target]");
        const menuPanels = document.querySelectorAll<HTMLElement>("[data-menu-panel]");

        menuSwitchButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const target = button.dataset.menuTarget;

            menuSwitchButtons.forEach((item) => {
              const isActive = item === button;
              item.classList.toggle("is-active", isActive);
              item.setAttribute("aria-selected", String(isActive));
            });

            menuPanels.forEach((panel) => {
              const isActive = panel.dataset.menuPanel === target;
              panel.classList.toggle("is-active", isActive);
              panel.hidden = !isActive;
            });
          });
        });
      </script>
    </div>
  </section>

  <section class="section reviews-section" id="reviews" aria-labelledby="reviews-title">
    <div class="container reviews-heading">
      <div>
        <span class="overline">Google reviews</span>
        <h2 class="scrawl" id="reviews-title">Locals love it</h2>
      </div>
      <div class="rating-stamp" aria-label="Rated 5.0 based on 71 Google reviews">
        <span class="rating-stamp__score">5.0</span>
        <span class="rating-stamp__stars" aria-hidden="true">★★★★★</span>
        <span class="rating-stamp__copy">based on 71 reviews</span>
      </div>
    </div>

    <div class="reviews-marquee" aria-label="Customer reviews">
      <div class="reviews-marquee__track">
        {scrollingReviews.map((review, index) => (
          <div class="reviews-marquee__item" aria-hidden={index >= googleReviews.length ? "true" : undefined}>
            <ReviewCard name={review.name} review={review.review} color={review.color} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="about" aria-labelledby="about-title">
    <div class="container about-grid">
      <div class="about-prints" aria-label="Photos from Paradiso Pizza">
        {aboutPhotos.map((photo) => (
          <figure class={`about-photo-card ${photo.modifier}`}>
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[220, 320, 440, 620]}
              sizes="(max-width: 720px) 76vw, 320px"
              loading="lazy"
            />
            {photo.caption && <figcaption class="print-caption">{photo.caption}</figcaption>}
          </figure>
        ))}
      </div>

      <div>
        <h2 class="scrawl" id="about-title">A little about us</h2>
        <p>
          Paradiso is a small Titirangi pizza spot making pizza, cannoli and
          tiramisu for the neighbourhood.
        </p>
        <p>
          We keep the menu tight: good dough, San Marzano tomato, fior di latte,
          a hot oven and a few house-made sweets for after.
        </p>
        <p>
          We opened in 2026 and have been lucky to be backed by Titirangi locals
          from day one.
        </p>
        {facebook && (
          <a
            class="social-link about-social-link"
            href={withBase(facebook.href)}
            target="_blank"
            rel="noopener noreferrer"
          >
            <FacebookIcon class="social-link__icon" size={20} />
            <span>Facebook updates</span>
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="section cta-band" id="order" aria-labelledby="order-title">
    <div class="container">
      <h2 class="cta-title" id="order-title">Hungry?</h2>
      <p class="lead">
        Order online for pickup or delivery. Fresh out of the oven, while the dough lasts.
      </p>
      <div class="hero-actions">
        <a
          class="btn btn--primary"
          href={withBase(site.orderUrl)}
          target="_blank"
          rel="noopener noreferrer"
        >
          Order Paradiso
        </a>
        <a class="btn btn--ghost" href={`tel:${site.phone}`}>Call {site.phoneDisplay}</a>
      </div>
      <div class="footprint-trail footprint-trail--center" aria-hidden="true">
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
      </div>
    </div>
  </section>
</BaseLayout>
