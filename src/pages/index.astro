---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import rooster from "@/assets/paradiso-rooster.jpg";
import { addOns, desserts, dips, pizzas } from "@/data/menu";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const featured = pizzas.filter(({ name }) =>
  ["Paradiso", "Inferno", "Dante", "Beatrice"].includes(name),
);
const midpoint = Math.ceil(pizzas.length / 2);
const pizzaColumns = [pizzas.slice(0, midpoint), pizzas.slice(midpoint)];
---

<BaseLayout title={site.name} description={site.description}>
  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero-grid">
      <div>
        <span class="overline">Wood-fired · Handmade</span>
        <h1 class="hero-title scrawl" id="hero-title">
          <span>Paradiso</span>
          <span>Pizza</span>
        </h1>
        <p class="lead">
          Pizza, cannoli and tiramisu in Titirangi village. Order online, pick up hot,
          and keep an eye on Facebook for the latest specials.
        </p>
        <div class="hero-actions">
          <a class="btn btn--ghost" href={withBase("#menu")}>View Menu</a>
          <a class="btn btn--primary" href={withBase(site.orderUrl)}>Order Online</a>
        </div>
        <p class="proof-marks" aria-hidden="true">/ * / *</p>
      </div>

      <figure class="print-frame">
        <Image
          src={rooster}
          alt="Hand-drawn rooster illustration used on the Paradiso Pizza menu"
          widths={[320, 480, 640]}
          sizes="(max-width: 720px) 80vw, 430px"
          loading="eager"
        />
        <figcaption class="print-caption">our mascot, Bruno.</figcaption>
      </figure>
    </div>
  </section>

  <section class="section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-heading">
        <h2 class="scrawl" id="featured-title">Pizza</h2>
        <p class="lead">Our most-loved pies, pulled from the same menu customers order from.</p>
      </div>

      <div class="featured-grid">
        {featured.map((pizza) => (
          <article class="rough-card">
            <h3>{pizza.name}</h3>
            <div class="card-rule" aria-hidden="true"></div>
            <p>{pizza.description}</p>
            <div class="price-row">
              <span class="price">{pizza.price}</span>
              <span class="muted">wood-fired</span>
            </div>
          </article>
        ))}
      </div>

      <div class="button-row button-row--center">
        <a class="btn btn--ghost" href={withBase("#menu")}>See full menu</a>
      </div>
    </div>
  </section>

  <section class="section section--surface" id="menu" aria-labelledby="menu-title">
    <div class="container">
      <div class="section-heading section-heading--center">
        <h2 class="scrawl" id="menu-title">The Menu</h2>
      </div>

      <div class="menu-layout">
        <div>
          <div class="menu-category-title">Pizza</div>
          <div class="menu-columns">
            {pizzaColumns.map((column) => (
              <ol class="menu-list">
                {column.map((pizza) => (
                  <li class="menu-entry">
                    <h3>{pizza.name}</h3>
                    <span class="price">{pizza.price}</span>
                    <p>{pizza.description}</p>
                  </li>
                ))}
              </ol>
            ))}
          </div>
        </div>

        <aside class="red-board" id="desserts" aria-labelledby="desserts-title">
          <div class="red-board-section">
            <h3 id="desserts-title">Desserts</h3>
            <ol class="menu-list">
              {desserts.map((item) => (
                <li class="menu-entry">
                  <h3>{item.name}</h3>
                  <span class="price">{item.price}</span>
                  <p>{item.description}</p>
                </li>
              ))}
            </ol>
          </div>

          <div class="red-board-section">
            <h3>Add-ons</h3>
            <ol class="side-list">
              {addOns.map((item) => (
                <li>{item.name} {item.price}</li>
              ))}
            </ol>
          </div>

          <div class="red-board-section">
            <h3>Dips <span class="price">$5</span></h3>
            <ol class="side-list">
              {dips.map((item) => (
                <li>{item.name}</li>
              ))}
            </ol>
          </div>

          <p class="menu-note">
            All pizzas are 12" wood-fired. Gluten-free base available +$3. Please
            advise of any allergies.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="section" id="about" aria-labelledby="about-title">
    <div class="container about-grid">
      <div class="oven-card" aria-hidden="true">
        <div class="oven-placeholder">
          <div>
            <p class="field-marks">/</p>
            <p>our wood-fired oven</p>
          </div>
        </div>
        <p class="print-caption">the heart of the kitchen</p>
      </div>

      <div>
        <h2 class="scrawl" id="about-title">A little slice of paradise</h2>
        <p>
          Paradiso makes pizza, cannoli and tiramisu for Titirangi locals, with a
          tight menu built around good dough, San Marzano tomato, fior di latte and
          house-made sweets.
        </p>
        <p>
          The menu keeps things simple: ten pizzas named from Dante, fired hot, plus
          cannoli, tiramisu, dips and add-ons for the table.
        </p>
        <p>
          The proof is local and current: established in 2026, rated 5.0 from 71
          Google reviews, and open from 4pm until sold out.
        </p>
        <p class="pull-quote">"Pizza, cannoli and tiramisu in the heart of Titirangi."</p>
        <p class="muted">Find us where dinner plans become a pizza order.</p>
      </div>
    </div>
  </section>

  <section class="section cta-band" id="order" aria-labelledby="order-title">
    <div class="container">
      <h2 class="cta-title" id="order-title">Hungry?</h2>
      <p class="lead">
        Order online for pickup or delivery. Fresh out of the oven, while the dough lasts.
      </p>
      <div class="hero-actions">
        <a class="btn btn--primary" href={withBase(site.orderUrl)}>Order Paradiso</a>
        <a class="btn btn--ghost" href={`tel:${site.phone}`}>Call {site.phoneDisplay}</a>
      </div>
      <p class="proof-marks" aria-hidden="true">* / * / *</p>
    </div>
  </section>
</BaseLayout>
