---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import CtaBand from "@/components/CtaBand.astro";
import { site } from "@/data/site";
import { services } from "@/data/services";
---

<BaseLayout
  title="Services"
  description={`Everything ${site.name} offers, in one place. Replace with a real 150–160 character description naming the key services and area.`}
>
  <section class="hero">
    <div class="container">
      <span class="overline">Services</span>
      <h1>What we can do for you</h1>
      <p class="lead">One sentence framing the full service range and who it's for.</p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="grid">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
