---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import ContactForm from "@/components/ContactForm.astro";
import FaqItem from "@/components/FaqItem.astro";
import { services } from "@/data/services";

// ─────────────────────────────────────────────────────────────────────────────
// THE DESIGN SYSTEM PAGE IS THE CONTRACT.
// Every page on the site is built only from what appears here. If a new
// section needs something the system can't express, extend global.css and
// SHOW IT HERE FIRST — then use it on the page.
// On build day this page is restyled for the client (tokens, fonts, signature)
// before any other page is touched.
// ─────────────────────────────────────────────────────────────────────────────

const colorTokens = [
  ["--ink", "#1d2025", "Main reading text on light surfaces"],
  ["--muted", "#5c6169", "Secondary copy, captions, small print"],
  ["--line", "#d9d6cf", "Borders, dividers, field edges"],
  ["--bg", "#f5f3ee", "Page background"],
  ["--surface", "#fffdf9", "Cards, forms, panels"],
  ["--dark", "#23262b", "Dark section bands and footer"],
  ["--dark-ink", "#f2f0eb", "Text on dark surfaces"],
  ["--brand", "#305d63", "Primary action — buttons, links, focus"],
  ["--brand-dark", "#234649", "Hover/active state of --brand"],
  ["--accent", "#b4552d", "Highlights, markers, small emphasis"],
];

const typeRoles = [
  ["Display", "h1", "A page headline set in the display face"],
  ["Section", "h2", "A section heading that frames a band of content"],
  ["Card", "h3", "A card or panel title"],
  ["Body", "p", "Body copy should be plain, specific, and useful — written for the customer, not for the business."],
  ["Utility", ".overline", "SECTION CONTEXT LABEL"],
];
---

<BaseLayout
  title="Design System"
  description="Internal design-system reference for this site."
  robots="noindex, nofollow"
>
  <section class="hero">
    <div class="container">
      <span class="overline">Internal reference</span>
      <h1>Design system</h1>
      <p class="lead">
        The single source of truth for this site. Pages are assembled only from the
        tokens, type roles, and components on this page.
      </p>
      <div class="ds-note">
        <strong>Build-day note for the agent:</strong> restyle this page first — replace
        the colour tokens, font roles, and design signature for the client's brand in
        <code>src/styles/global.css</code>, review it here, and only then build out the
        real pages. Record the chosen design signature below.
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Foundation</span>
        <h2>Design signature</h2>
        <p class="lead">
          Every build picks one memorable visual idea tied to the business's real
          subject matter (material, place, process, or proof) and carries it through
          the site. Describe it here once chosen.
        </p>
      </div>
      <div class="ds-note">
        <strong>Signature:</strong> not yet chosen — this template ships neutral on
        purpose. If the finished design could be pasted onto any generic local-service
        or SaaS site unchanged, it isn't done.
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Tokens</span>
        <h2>Colour roles</h2>
        <p class="lead">
          Named variables in <code>:root</code>, one per role. Components reference
          tokens, never raw hex.
        </p>
      </div>
      <div class="swatch-grid">
        {colorTokens.map(([token, hex, role]) => (
          <div class="swatch">
            <div class="swatch-chip" style={`background: var(${token});`}></div>
            <div class="swatch-meta">
              <code>{token}</code> · {hex}
              <br />
              <span class="muted">{role}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Tokens</span>
        <h2>Typography roles</h2>
        <p class="lead">
          One display face for headings, one body face for everything else — chosen
          deliberately per project.
        </p>
      </div>
      {typeRoles.map(([role, selector, sample]) => (
        <div style="margin-bottom: 28px;">
          <span class="overline">{role} — <code>{selector}</code></span>
          {selector === "h1" && <h1 style="margin:0;">{sample}</h1>}
          {selector === "h2" && <h2 style="margin:0;">{sample}</h2>}
          {selector === "h3" && <h3 style="margin:0;">{sample}</h3>}
          {selector === "p" && <p style="margin:0; max-width:58ch;">{sample}</p>}
          {selector === ".overline" && <span class="overline">{sample}</span>}
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Components</span>
        <h2>Buttons</h2>
      </div>
      <div class="hero-actions">
        <a class="btn btn--primary" href="#buttons">Primary action</a>
        <a class="btn btn--ghost" href="#buttons">Secondary action</a>
      </div>
      <p class="muted" style="margin-top: 16px;">
        Labels state the action: "Get a quote", "Book a measure" — never "Learn more"
        on a primary button.
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Components</span>
        <h2>Service cards</h2>
        <p class="lead">
          Cards are for repeated items only — never the default wrapper for every
          section. No nested cards.
        </p>
      </div>
      <div class="grid">
        {services.slice(0, 3).map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <div class="section-heading">
          <span class="overline">Components</span>
          <h2>Form fields</h2>
        </div>
        <ContactForm />
      </div>
      <div>
        <div class="section-heading">
          <span class="overline">Components</span>
          <h2>FAQ / disclosure</h2>
        </div>
        <FaqItem
          question="How does the FAQ component behave?"
          answer="It uses a native details/summary element, so it's keyboard-accessible with no JavaScript."
        />
        <FaqItem
          question="Where does FAQ content live?"
          answer="In src/data/faqs.ts — it also feeds FAQPage structured data for search engines."
        />

        <div class="section-heading" style="margin-top: 40px;">
          <span class="overline">Components</span>
          <h2>Checklist</h2>
        </div>
        <ul class="checklist">
          <li>Used for what's-included lists and proof points</li>
          <li>Markers use the accent token</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Patterns</span>
        <h2>Dark section band</h2>
        <p class="lead">
          Sections alternate: default background, surface band, and this dark band for
          the closing call-to-action. Ghost buttons adapt automatically.
        </p>
      </div>
      <a class="btn btn--ghost" href="#dark">Ghost button on dark</a>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div>
        <h2>Do</h2>
        <ul class="checklist">
          <li>Reference tokens, never raw hex, in components</li>
          <li>Build every page from classes shown on this page</li>
          <li>Keep repeated content in <code>src/data/*.ts</code></li>
          <li>Use Lucide SVG icons through the icon map</li>
          <li>Write plain, specific copy with action-stating buttons</li>
          <li>Respect <code>prefers-reduced-motion</code></li>
        </ul>
      </div>
      <div>
        <h2>Don't</h2>
        <ul class="checklist">
          <li>Add one-off inline styles or per-page CSS for things the system covers</li>
          <li>Use emoji as icons, fake metrics, or meaningless badges</li>
          <li>Wrap every section in a card, or nest cards</li>
          <li>Use purple gradients or generic AI-template hero layouts</li>
          <li>Hardcode business details — they live in <code>src/data/site.ts</code></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
