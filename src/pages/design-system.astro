---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ReviewCard from "@/components/ReviewCard.astro";
import { pizzas } from "@/data/menu";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const colorTokens = [
  ["--ink", "#1a1a1a", "Typewriter ink, borders and rough shadows"],
  ["--ash", "#5a5a4a", "Muted captions and secondary notes"],
  ["--paper", "#f7f5ef", "Graph-paper page background"],
  ["--paper-strong", "#fbfaf5", "Menu cards and raised paper blocks"],
  ["--cream", "#f0ede4", "Rooster matting and warm print surfaces"],
  ["--menu-red", "#d42b2b", "Handwritten headings, rules and primary actions"],
  ["--brand-red", "#760201", "Logo red, reserved for brand lockups"],
];

const featured = pizzas.slice(0, 2);
---

<BaseLayout
  title="Design System"
  description="Internal Paradiso Pizza design-system reference."
  robots="noindex, nofollow"
>
  <section class="hero">
    <div class="container">
      <span class="overline">Internal reference</span>
      <h1 class="scrawl">Design system</h1>
      <p class="lead">
        The public site is a one-page menu experience based on Paradiso's printed
        menu: graph paper, red hand lettering, typewriter copy and rough print boxes.
      </p>
      <div class="ds-note">
        <strong>Signature:</strong> the website behaves like an expanded version of
        the printed menu, with the rooster print, red-ruled dessert board and
        typewriter price lists carrying the brand across the page.
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Foundation</span>
        <h2>Colour roles</h2>
      </div>
      <div class="swatch-grid">
        {colorTokens.map(([token, hex, role]) => (
          <div class="swatch">
            <div class="swatch-chip" style={`background: var(${token});`}></div>
            <div class="swatch-meta">
              <code>{token}</code> · {hex}
              <br />
              <span class="muted">{role}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Typography</span>
        <h2>Type roles</h2>
      </div>
      <div class="grid">
        <div>
          <h3>Hand lettering</h3>
          <p class="lead">Caveat, used for the red headline voice and menu item names.</p>
        </div>
        <div>
          <h3 class="type-sample">Typewriter copy</h3>
          <p class="lead">Special Elite, used for body text, prices, buttons and utility copy.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Components</span>
        <h2>Buttons and cards</h2>
      </div>
      <div class="hero-actions">
        <a class="btn btn--ghost" href={withBase("#menu")}>View Menu</a>
        <a class="btn btn--primary" href={withBase(site.orderUrl)}>Order Online</a>
      </div>
      <div class="featured-grid ds-space-top">
        {featured.map((pizza) => (
          <article class="rough-card">
            <h3>{pizza.name}</h3>
            <div class="card-rule" aria-hidden="true"></div>
            <p>{pizza.description}</p>
            <div class="price-row">
              <span class="price">{pizza.price}</span>
              <span class="muted">wood-fired</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Components</span>
        <h2>Menu list and red board</h2>
      </div>
      <div class="menu-layout">
        <ol class="menu-list">
          {pizzas.slice(0, 3).map((pizza) => (
            <li class="menu-entry">
              <h3>{pizza.name}</h3>
              <span class="price">{pizza.price}</span>
              <p>{pizza.description}</p>
            </li>
          ))}
        </ol>
        <div class="red-board">
          <h3>Desserts</h3>
          <p class="lead">Red-ruled boxes are reserved for the dessert/add-on board and strong calls to action.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <div class="section-heading">
        <span class="overline">Components</span>
        <h2>Review tile</h2>
        <p class="lead">
          Square social-proof tile for the upcoming Google reviews strip.
        </p>
      </div>
      <div class="review-card-demo">
        <ReviewCard
          name="Mia"
          color="blue"
          review="Best pizza in Titirangi. The dough is perfect and the tiramisu is worth adding every time."
        />
      </div>
    </div>
  </section>
</BaseLayout>
