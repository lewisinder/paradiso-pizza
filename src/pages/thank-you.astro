---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { thankYouPage } from "@/data/pages";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";
---

<BaseLayout
  title={thankYouPage.heading}
  description="Your enquiry has been received."
  robots="noindex, nofollow"
>
  <section class="hero">
    <div class="container">
      <span class="overline">{thankYouPage.overline}</span>
      <h1>{thankYouPage.heading}</h1>
      <p class="lead">
        {thankYouPage.message}
        {thankYouPage.phoneNote && (
          <>
            {" "}{thankYouPage.phoneNote}
            <a href={`tel:${site.phone}`}> {site.phoneDisplay}</a>.
          </>
        )}
      </p>
      <div class="hero-actions">
        <a class="btn btn--ghost" href={withBase("/")}>{thankYouPage.homeButtonLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
