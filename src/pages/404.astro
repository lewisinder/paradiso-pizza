---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";
---

<BaseLayout
  title="Page not found"
  description="That page doesn't exist."
  robots="noindex, nofollow"
>
  <section class="hero">
    <div class="container">
      <span class="overline">404</span>
      <h1>That page doesn't exist</h1>
      <p class="lead">
        The link may be old or mistyped. Head back to the homepage, or get in touch if
        you were looking for something specific.
      </p>
      <div class="hero-actions">
        <a class="btn btn--primary" href={withBase("/")}>Back to the homepage</a>
        <a class="btn btn--ghost" href={`tel:${site.phone}`}>Call {site.phoneDisplay}</a>
      </div>
      {site.email && (
        <p class="lead">
          Or email <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      )}
    </div>
  </section>
</BaseLayout>
