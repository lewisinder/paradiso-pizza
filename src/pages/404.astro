---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { notFoundPage } from "@/data/pages";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";
---

<BaseLayout
  title={notFoundPage.heading}
  description="That page doesn't exist."
  robots="noindex, nofollow"
>
  <section class="hero">
    <div class="container">
      <span class="overline">{notFoundPage.overline}</span>
      <h1>{notFoundPage.heading}</h1>
      <p class="lead">{notFoundPage.message}</p>
      <div class="hero-actions">
        <a class="btn btn--primary" href={withBase("/")}>{notFoundPage.homeButtonLabel}</a>
        {notFoundPage.phoneNote && (
          <a class="btn btn--ghost" href={`tel:${site.phone}`}>
            {notFoundPage.phoneNote} {site.phoneDisplay}
          </a>
        )}
      </div>
      {site.email && notFoundPage.emailNote && (
        <p class="lead">
          {notFoundPage.emailNote} <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      )}
    </div>
  </section>
</BaseLayout>
