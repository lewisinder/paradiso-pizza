---
import FacebookIcon from "@/components/FacebookIcon.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const year = new Date().getFullYear();
const facebook = site.social.find((item) => item.label.toLowerCase() === "facebook") ?? site.social[0];
---

<footer class="site-footer" id="contact">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4 class="footer-brand">Paradiso Pizza</h4>
        <span class="footer-rule" aria-hidden="true"></span>
        <p class="muted">Pizza, cannoli and tiramisu in the heart of Titirangi.</p>
      </div>
      <div>
        <h4>Find us</h4>
        <ul>
          <li>{site.address.street}, {site.address.locality}, {site.address.region} {site.address.postalCode}</li>
          {facebook && (
            <li>
              <a
                class="social-link"
                href={withBase(facebook.href)}
                target="_blank"
                rel="noopener noreferrer"
              >
                <FacebookIcon class="social-link__icon" size={18} />
                <span>Facebook updates</span>
              </a>
            </li>
          )}
        </ul>
      </div>
      <div>
        <h4>Hours</h4>
        <ul>
          {site.hours.map((hours) => (
            <li>{hours}</li>
          ))}
        </ul>
      </div>
      <div>
        <h4>Order</h4>
        <ul>
          <li><a href={`tel:${site.phone}`}>{site.phoneDisplay}</a></li>
          {site.email && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
          <li>
            <a href={withBase(site.orderUrl)} target="_blank" rel="noopener noreferrer">
              Order online
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {site.legalName}. Made with love and flour.</span>
      <span class="footprint-trail footprint-trail--footer" aria-hidden="true">
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
      </span>
    </div>
  </div>
</footer>
