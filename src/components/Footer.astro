---
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const year = new Date().getFullYear();
---

<footer class="site-footer" id="contact">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4 class="footer-brand">Paradiso</h4>
        <span class="footer-rule" aria-hidden="true"></span>
        <p class="muted">Pizza, cannoli and tiramisu in the heart of Titirangi.</p>
      </div>
      <div>
        <h4>Find us</h4>
        <ul>
          <li>{site.address.locality}, {site.address.region}</li>
          <li>{site.areas.join(" · ")}</li>
          <li><a href={withBase(site.social[0].href)}>Facebook updates</a></li>
        </ul>
      </div>
      <div>
        <h4>Hours</h4>
        <ul>
          {site.hours.map((hours) => (
            <li>{hours}</li>
          ))}
          <li class="muted">Check Facebook for daily sell-out updates.</li>
        </ul>
      </div>
      <div>
        <h4>Order</h4>
        <ul>
          <li><a href={`tel:${site.phone}`}>{site.phoneDisplay}</a></li>
          {site.email && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
          <li>
            <a href={withBase(site.orderUrl)} target="_blank" rel="noopener noreferrer">
              Order online
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {site.legalName}. Made with love and flour.</span>
      <span class="footprint-trail footprint-trail--footer" aria-hidden="true">
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
      </span>
    </div>
  </div>
</footer>
