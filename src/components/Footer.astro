---
import FacebookIcon from "@/components/FacebookIcon.astro";
import InstagramIcon from "@/components/InstagramIcon.astro";
import { site } from "@/data/site";
import { withBase } from "@/lib/base";

const year = new Date().getFullYear();
const socialIcons: Record<string, typeof FacebookIcon> = {
  facebook: FacebookIcon,
  instagram: InstagramIcon,
};
---

<footer class="site-footer" id="contact">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4 class="footer-brand">{site.name}</h4>
        <span class="footer-rule" aria-hidden="true"></span>
        <p class="muted">{site.tagline}</p>
      </div>
      <div>
        <h4>{site.footer.findUsHeading}</h4>
        <ul>
          <li>{site.address.street}, {site.address.locality}, {site.address.region} {site.address.postalCode}</li>
          {site.social.map((item) => {
            const Icon = socialIcons[item.label.toLowerCase()];
            return (
              <li>
                <a
                  class="social-link"
                  href={withBase(item.href)}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {Icon && <Icon class="social-link__icon" size={18} />}
                  <span>{item.label} updates</span>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
      <div>
        <h4>{site.footer.hoursHeading}</h4>
        <ul>
          {site.hours.map((hours) => (
            <li>{hours}</li>
          ))}
        </ul>
      </div>
      <div>
        <h4>{site.footer.contactHeading}</h4>
        <ul>
          <li><a href={`tel:${site.phone}`}>{site.phoneDisplay}</a></li>
          {site.email && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
          <li>
            <a href={withBase(site.orderUrl)} target="_blank" rel="noopener noreferrer">
              {site.footer.orderLinkLabel}
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>
        © {year} {site.legalName}. {site.footer.bottomNote} ·
        <a
          class="footer-credit"
          href="https://theblueprintcollective.co.nz/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Designed by The Blueprint Collective
        </a> ·
        <a class="footer-credit" href={withBase("/privacy/")}>Privacy Policy</a>
      </span>
      <span class="footprint-trail footprint-trail--footer" aria-hidden="true">
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
        <span class="footprint-mark"></span>
      </span>
    </div>
  </div>
</footer>
